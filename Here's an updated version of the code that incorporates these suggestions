import re
import datetime

# Define a regular expression pattern for parsing log data in the format of [YYYY-MM-DDTHH:mm:ssZ] some log message
BLESS_LOG = r"(?P<timestamp>.*?)\s(?P<logdata>.*)"

# Define a function to parse the timestamp and log data from the log message
def parse_timestamp(message):
    match = re.match(BLESS_LOG, message)
    if match:
        # Extract the timestamp and log data from the match object
        timestamp = match.group("timestamp")
        logdata = match.group("logdata")
        # Convert the timestamp to a datetime object
        return datetime.datetime.strptime(timestamp, "%Y-%m-%dT%H:%M:%SZ")
    else:
        # If the message does not match the pattern, return None
        return None
